import numpy as np
import matplotlib.pyplot as plt

# Total population
N = 1000

# Initial number of infected and recovered individuals
I0 = 1
R0 = 0
S0 = N - I0 - R0

# Infection rate (beta) and recovery rate (gamma)
beta = 0.3
gamma = 0.1

# Time (days)
days = 160
t = np.linspace(0, days, days)

# Lists to store values
S = [S0]
I = [I0]
R = [R0]

# SIR Model equations
for i in range(1, days):
    new_infected = beta * S[-1] * I[-1] / N
    new_recovered = gamma * I[-1]

    S.append(S[-1] - new_infected)
    I.append(I[-1] + new_infected - new_recovered)
    R.append(R[-1] + new_recovered)

# Plot the data
plt.figure(figsize=(10,6))
plt.plot(t, S, label='Susceptible')
plt.plot(t, I, label='Infected')
plt.plot(t, R, label='Recovered')

plt.xlabel('Days')
plt.ylabel('Number of People')
plt.title('Disease Spread Analysis using SIR Model')
plt.legend()
plt.grid()

plt.show()
